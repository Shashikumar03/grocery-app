# Copy to env.properties in this folder and fill in real values.
# env.properties is gitignored — do not commit secrets.

# Razorpay (Dashboard → API Keys + Webhooks → Secret)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Database (Railway / local)
MYSQL_PUBLIC_URL=mysql://localhost:3306/grocery
MYSQLUSER=root
MYSQLPASSWORD=your_db_password

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
